{% comment %}
  Section: Shop the Look
  Source theme: masons/main
  Created: 2026-03-25
  Replicates the editorial outfit showcase grid from the Mason's source store.
  Each "look" block has a lifestyle image + linked products shown as cards.
{% endcomment %}

<script
  src="{{ 'shop-the-look.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="shop-the-look-{{ section.id }}"
>
  {% if section.settings.heading != blank %}
    <div class="shop-the-look__header">
      <h2 class="shop-the-look__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="shop-the-look__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <shop-the-look-component class="shop-the-look__grid">
    {% for block in section.blocks %}
      {% if block.type == 'look' %}
        <div
          class="shop-the-look__card"
          {{ block.shopify_attributes }}
          data-look-index="{{ forloop.index0 }}"
        >
          <div class="shop-the-look__image-wrapper">
            {% if block.settings.image != blank %}
              {% render 'image', image: block.settings.image, class: 'shop-the-look__image' %}
            {% else %}
              {{ 'hero-apparel-' | append: forloop.index | placeholder_svg_tag: 'shop-the-look__image placeholder-svg' }}
            {% endif %}

            {% if block.settings.look_label != blank %}
              <span class="shop-the-look__label">{{ block.settings.look_label }}</span>
            {% endif %}
          </div>

          <div class="shop-the-look__products">
            {% assign product_handles = block.settings.product_list %}
            {% for product in product_handles %}
              <a href="{{ product.url }}" class="shop-the-look__product-card">
                {% if product.featured_image != blank %}
                  <img
                    src="{{ product.featured_image | image_url: width: 120 }}"
                    alt="{{ product.title | escape }}"
                    width="60"
                    height="75"
                    loading="lazy"
                    class="shop-the-look__product-image"
                  >
                {% endif %}
                <div class="shop-the-look__product-info">
                  <span class="shop-the-look__product-title">{{ product.title }}</span>
                  <span class="shop-the-look__product-price">{{ product.price | money }}</span>
                </div>
              </a>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </shop-the-look-component>
</div>

{% stylesheet %}
  .shop-the-look__header {
    text-align: center;
    margin-block-end: var(--gap-2xl, 32px);
  }

  .shop-the-look__title {
    font-size: var(--font-size-heading, 1.75rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .shop-the-look__subtitle {
    font-size: var(--font-size-body, 1rem);
    margin-block-start: var(--gap-sm, 8px);
    opacity: 0.7;
  }

  .shop-the-look__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap-xl, 24px);

    @media screen and (max-width: 989px) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media screen and (max-width: 749px) {
      grid-template-columns: 1fr;
    }
  }

  .shop-the-look__card {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md, 12px);
  }

  .shop-the-look__image-wrapper {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--border-radius, 0);
  }

  .shop-the-look__image-wrapper img,
  .shop-the-look__image-wrapper svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .shop-the-look__label {
    position: absolute;
    bottom: var(--gap-md, 12px);
    left: var(--gap-md, 12px);
    background: var(--color-background, #fff);
    color: var(--color-foreground, #000);
    padding: 4px 12px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .shop-the-look__products {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm, 8px);
  }

  .shop-the-look__product-card {
    display: flex;
    align-items: center;
    gap: var(--gap-sm, 8px);
    text-decoration: none;
    color: var(--color-foreground);
    padding: 4px;
    transition: opacity 0.2s ease;
  }

  .shop-the-look__product-card:hover {
    opacity: 0.7;
  }

  .shop-the-look__product-image {
    width: 60px;
    height: 75px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .shop-the-look__product-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .shop-the-look__product-title {
    font-size: 0.85rem;
    line-height: 1.3;
  }

  .shop-the-look__product-price {
    font-size: 0.8rem;
    font-weight: 600;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Shop the Look",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP THE LOOK"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "look",
      "name": "Look",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Lifestyle image"
        },
        {
          "type": "text",
          "id": "look_label",
          "label": "Look label",
          "info": "E.g. 'Men's Casual', 'Women's Tailored'"
        },
        {
          "type": "product_list",
          "id": "product_list",
          "label": "Products in this look",
          "limit": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop the Look",
      "category": "Products",
      "blocks": [
        { "type": "look", "settings": { "look_label": "Look 1" } },
        { "type": "look", "settings": { "look_label": "Look 2" } },
        { "type": "look", "settings": { "look_label": "Look 3" } }
      ]
    }
  ]
}
{% endschema %}
