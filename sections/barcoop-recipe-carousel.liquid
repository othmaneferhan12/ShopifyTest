{{ 'barcoop-recipe-carousel.css' | asset_url | stylesheet_tag }}

<section class="barcoop-recipes" data-section-id="{{ section.id }}">
  <div class="barcoop-recipes__inner">
    <div class="barcoop-recipes__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="barcoop-recipes__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <div class="barcoop-recipes__nav">
        <button class="barcoop-recipes__prev" aria-label="Previous recipes">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="barcoop-recipes__next" aria-label="Next recipes">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>

    <div class="swiper barcoop-recipes__swiper">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide barcoop-recipes__slide" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link }}" class="barcoop-recipes__card">
              <div class="barcoop-recipes__card-image">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 500 }}"
                    alt="{{ block.settings.title | escape }}"
                    width="400"
                    height="400"
                    loading="lazy"
                  >
                {%- endif -%}
              </div>
              <div class="barcoop-recipes__card-info">
                <h3 class="barcoop-recipes__card-title">{{ block.settings.title }}</h3>
                {%- if block.settings.spirit != blank -%}
                  <p class="barcoop-recipes__card-spirit">{{ block.settings.spirit }}</p>
                {%- endif -%}
              </div>
            </a>
          </div>
        {%- endfor -%}
      </div>
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="barcoop-recipes__cta">
        <a href="{{ section.settings.button_link }}" class="barcoop-recipes__button">
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof Swiper === 'undefined') return;
    new Swiper('.barcoop-recipes__swiper', {
      slidesPerView: 1.2,
      spaceBetween: 16,
      loop: false,
      navigation: {
        nextEl: '.barcoop-recipes__next',
        prevEl: '.barcoop-recipes__prev'
      },
      breakpoints: {
        480: { slidesPerView: 1.5, spaceBetween: 16 },
        768: { slidesPerView: 2.5, spaceBetween: 20 },
        1024: { slidesPerView: 3.5, spaceBetween: 24 }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Barcoop Recipe Carousel",
  "tag": "section",
  "class": "barcoop-recipes-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recipes"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "View All Recipes"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "recipe",
      "name": "Recipe Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Recipe Title",
          "default": "Classic Margarita"
        },
        {
          "type": "text",
          "id": "spirit",
          "label": "Spirit Type",
          "default": "Tequila"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Recipe Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Recipe Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barcoop Recipe Carousel",
      "blocks": [
        { "type": "recipe", "settings": { "title": "Dark and Stormy", "spirit": "Rum" } },
        { "type": "recipe", "settings": { "title": "Vodka Gimlet", "spirit": "Vodka" } },
        { "type": "recipe", "settings": { "title": "Virgin Piña Colada", "spirit": "Non-Alcoholic" } },
        { "type": "recipe", "settings": { "title": "Spicy Strawberry Margarita", "spirit": "Tequila" } },
        { "type": "recipe", "settings": { "title": "Perfect Piña Colada", "spirit": "Rum" } },
        { "type": "recipe", "settings": { "title": "Spicy Strawberry Lime Soda", "spirit": "Non-Alcoholic" } }
      ]
    }
  ]
}
{% endschema %}
